# Copy to .env and adjust if needed. Requires PostgreSQL on localhost:5432 (see repo root: docker compose up postgres -d).
DATABASE_URL=postgresql+asyncpg://finbro:finbro@localhost:5432/finbro
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000
WEB3_RPC_URL=
WEB3_PRIVATE_KEY=
FBT_CONTRACT_ADDRESS=
SEPOLIA_CHAIN_ID=11155111
MOCK_WEB3=true

# Gemini AI configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash
